
{
  "entities": {
    "Word": {
      "title": "Word",
      "description": "A spelling word for the game",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "definition": { "type": "string" },
        "exampleSentence": { "type": "string" },
        "theme": { "type": "string" },
        "difficulty": { 
          "type": "string", 
          "enum": ["beginner", "intermediate", "advanced"],
          "description": "The manually assigned difficulty level for this word"
        },
        "imageUrl": { "type": "string", "description": "URL of the image representing the word" },
        "phonemes": { "type": "string", "description": "IPA phonetic representation of the word" },
        "audioUrl": { "type": "string", "description": "Data URI of the pronunciation audio" },
        "userId": { "type": "string", "description": "The user who created this custom word" }
      },
      "required": ["word", "definition", "difficulty"]
    },
    "UserStats": {
      "title": "UserStats",
      "description": "User's overall progress and achievements",
      "type": "object",
      "properties": {
        "stars": { "type": "number" },
        "wordsMastered": { "type": "number" },
        "correctLetters": { "type": "number" },
        "activeClassId": { "type": "string", "description": "The ID of the class the pupil is currently in" }
      }
    },
    "Classroom": {
      "title": "Classroom",
      "description": "A virtual classroom created by a teacher",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string", "description": "Unique join code" },
        "teacherId": { "type": "string" },
        "assignedWordIds": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "IDs of words assigned to this class"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "code", "teacherId"]
    },
    "PupilProgress": {
      "title": "PupilProgress",
      "description": "Specific progress for a pupil within a class",
      "type": "object",
      "properties": {
        "stars": { "type": "number" },
        "wordsMastered": { "type": "number" },
        "pupilName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "words/{wordId}": {
      "schema": "#/entities/Word",
      "description": "Collection of spelling words"
    },
    "users/{userId}/stats/main": {
      "schema": "#/entities/UserStats",
      "description": "User specific overall statistics"
    },
    "classrooms/{classId}": {
      "schema": "#/entities/Classroom",
      "description": "Collection of classrooms"
    },
    "classrooms/{classId}/pupils/{userId}": {
      "schema": "#/entities/PupilProgress",
      "description": "Progress of a specific pupil in a classroom"
    }
  }
}
